  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@capacitor/assets": "^3.0.5",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/sockjs-client": "^1.5.4",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
